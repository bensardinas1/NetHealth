{
  "showOverlay": true,
  "notifyOnChange": true,
  "targets": [
    {
      "name": "Default Gateway",
      "type": "ping",
      "host": "auto",
      "timeoutMs": 2000,
      "thresholdMs": 100,
      "pollIntervalSeconds": 30,
      "enabled": true
    },
    {
      "name": "Cloudflare DNS",
      "type": "ping",
      "host": "1.1.1.1",
      "timeoutMs": 2000,
      "thresholdMs": 50,
      "pollIntervalSeconds": 30,
      "enabled": true
    },
    {
      "name": "DNS Resolution",
      "type": "dns",
      "host": "1.1.1.1",
      "resolve": "google.com",
      "timeoutMs": 3000,
      "pollIntervalSeconds": 30,
      "enabled": true
    },
    {
      "name": "GitHub",
      "type": "http",
      "url": "https://github.com",
      "timeoutMs": 5000,
      "expectedStatusCode": 200,
      "pollIntervalSeconds": 60,
      "enabled": true
    }
  ]
}
